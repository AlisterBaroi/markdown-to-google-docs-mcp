# APP_URL: Where this applet is hosted (for self-referential links, OAuth callbacks, and API endpoints). 
# Needed to automatically inject this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# Firebase Credentials (Requirement):
# Fill these Firebase project env variables, or drop a firebase-applet-config.json file at the root of this repo.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
